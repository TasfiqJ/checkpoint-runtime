{
  "dashboard": {
    "title": "Cluster Health",
    "uid": "cluster-health",
    "tags": ["checkpoint-runtime"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Active Workers",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "controlplane_runs_active",
            "legendFormat": "active runs"
          }
        ]
      },
      {
        "title": "Worker Heartbeat Lag",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "controlplane_worker_heartbeat_lag_seconds",
            "legendFormat": "{{worker_id}}"
          }
        ]
      },
      {
        "title": "Backpressure Queue Depth",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "dataplane_backpressure_queue_depth",
            "legendFormat": "queue depth"
          }
        ]
      },
      {
        "title": "gRPC Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(dataplane_grpc_requests_total{status!=\"OK\"}[5m])",
            "legendFormat": "{{method}} {{status}}"
          }
        ]
      },
      {
        "title": "S3 Retry Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "rate(dataplane_s3_retry_total[5m])",
            "legendFormat": "{{error}}"
          }
        ]
      },
      {
        "title": "Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "dataplane_memory_bytes",
            "legendFormat": "{{type}}"
          }
        ]
      }
    ]
  }
}
