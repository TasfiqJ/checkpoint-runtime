{
  "dashboard": {
    "title": "Checkpoint Overview",
    "uid": "ckpt-overview",
    "tags": ["checkpoint-runtime"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Checkpoint Write Throughput (bytes/sec)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(ckpt_shard_write_bytes_total[5m])",
            "legendFormat": "{{run_id}} rank-{{rank}}"
          }
        ]
      },
      {
        "title": "Checkpoint Commit Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(ckpt_commit_total[5m])",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "title": "Shard Write Latency (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, rate(ckpt_shard_write_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(ckpt_shard_write_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(ckpt_shard_write_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "GC Shards Deleted",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "ckpt_gc_shards_deleted_total",
            "legendFormat": "deleted"
          }
        ]
      }
    ]
  }
}
